<Page
    x:Class="Text_Grab.Pages.EditTextWindowSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="EditTextWindowSettings"
    d:DesignHeight="900"
    d:DesignWidth="800"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Visible">
    <StackPanel Margin="20,12,40,40" Orientation="Vertical">
        <TextBlock Style="{StaticResource TextHeader}" Text="Edit Text Window Settings" />

        <TextBlock
            Margin="0,12,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Window Behavior" />

        <CheckBox
            x:Name="EditWindowStartFullscreenCheckBox"
            Margin="0,4,0,0"
            Click="EditWindowStartFullscreenCheckBox_Click"
            Content="Launch Fullscreen Grab on startup" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="When opening an empty Edit Text Window, immediately trigger a Fullscreen Grab. The window restores from minimized once text is captured." />

        <CheckBox
            x:Name="EditWindowIsOnTopCheckBox"
            Margin="0,4,0,0"
            Click="EditWindowIsOnTopCheckBox_Click"
            Content="Keep window always on top" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="The Edit Text Window will stay above all other windows." />

        <CheckBox
            x:Name="EditWindowIsWordWrapOnCheckBox"
            Margin="0,4,0,0"
            Click="EditWindowIsWordWrapOnCheckBox_Click"
            Content="Enable word wrap" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Wrap long lines of text instead of scrolling horizontally." />

        <CheckBox
            x:Name="RestoreEtwPositionsCheckBox"
            Margin="0,4,0,0"
            Click="RestoreEtwPositionsCheckBox_Click"
            Content="Restore window size and position on startup" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Remember and restore the Edit Text Window's size and position between sessions." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Toolbar and UI" />

        <CheckBox
            x:Name="EditWindowBottomBarIsHiddenCheckBox"
            Margin="0,4,0,0"
            Click="EditWindowBottomBarIsHiddenCheckBox_Click"
            Content="Hide bottom toolbar" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Collapse the bottom bar that contains status text, character info, regex buttons, and the language picker." />

        <CheckBox
            x:Name="EtwShowLangPickerCheckBox"
            Margin="0,4,0,0"
            Click="EtwShowLangPickerCheckBox_Click"
            Content="Show language picker in toolbar" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Add an OCR language selector control to the bottom bar." />

        <CheckBox
            x:Name="EtwUseMarginsCheckBox"
            Margin="0,4,0,0"
            Click="EtwUseMarginsCheckBox_Click"
            Content="Show text margins" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Add responsive horizontal padding to the text area (50–160px depending on window width) to improve readability on wider windows." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Default Font" />

        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TextBodyNormal}"
                Text="Font family:" />
            <TextBox
                x:Name="FontFamilyTextBox"
                Width="200"
                Margin="12,0,0,0"
                LostFocus="FontFamilyTextBox_LostFocus" />
        </StackPanel>

        <StackPanel
            Margin="0,8,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TextBodyNormal}"
                Text="Font size:" />
            <Slider
                x:Name="FontSizeSlider"
                Width="200"
                Margin="12,0,0,0"
                IsSnapToTickEnabled="True"
                Maximum="72"
                Minimum="8"
                SmallChange="1"
                TickFrequency="1"
                ValueChanged="FontSizeSlider_ValueChanged" />
            <TextBlock
                x:Name="FontSizeValueText"
                Width="36"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                Style="{StaticResource TextBodyNormal}" />
        </StackPanel>

        <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
            <CheckBox
                x:Name="IsFontBoldCheckBox"
                Click="IsFontBoldCheckBox_Click"
                Content="Bold" />
            <CheckBox
                x:Name="IsFontItalicCheckBox"
                Margin="16,0,0,0"
                Click="IsFontItalicCheckBox_Click"
                Content="Italic" />
            <CheckBox
                x:Name="IsFontUnderlineCheckBox"
                Margin="16,0,0,0"
                Click="IsFontUnderlineCheckBox_Click"
                Content="Underline" />
            <CheckBox
                x:Name="IsFontStrikeoutCheckBox"
                Margin="16,0,0,0"
                Click="IsFontStrikeoutCheckBox_Click"
                Content="Strikeout" />
        </StackPanel>
        <TextBlock
            Margin="0,4,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Default font used when opening a new Edit Text Window." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Status Bar" />

        <TextBlock
            Margin="0,0,0,6"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Choose which details appear as clickable buttons in the Edit Text Window status bar." />

        <CheckBox
            x:Name="EtwShowWordCountCheckBox"
            Margin="0,4,0,0"
            Click="EtwShowWordCountCheckBox_Click"
            Content="Show word count" />
        <TextBlock
            Margin="24,0,0,6"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Adds word count alongside the cursor line and column in the status bar (e.g. &quot;Wrds 42, Ln 3, Col 7&quot;)." />

        <CheckBox
            x:Name="EtwShowCharDetailsCheckBox"
            Margin="0,4,0,0"
            Click="EtwShowCharDetailsCheckBox_Click"
            Content="Show character details" />
        <TextBlock
            Margin="24,0,0,6"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="For a single selected character, shows its Unicode code point (e.g. U+0041). For a longer selection, shows the character count." />

        <CheckBox
            x:Name="EtwShowMatchCountCheckBox"
            Margin="0,4,0,0"
            Click="EtwShowMatchCountCheckBox_Click"
            Content="Show exact match count" />
        <TextBlock
            Margin="24,0,0,6"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Searches the full text for exact copies of the current selection. Click the count to open Find and Replace." />

        <CheckBox
            x:Name="EtwShowRegexPatternCheckBox"
            Margin="0,4,0,0"
            Click="EtwShowRegexPatternCheckBox_Click"
            Content="Show generated regex pattern" />
        <TextBlock
            Margin="24,0,0,6"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Displays a regex pattern derived from the current selection. Scroll the mouse wheel over the button to adjust match precision." />

        <CheckBox
            x:Name="EtwShowSimilarMatchesCheckBox"
            Margin="0,4,0,8"
            Click="EtwShowSimilarMatchesCheckBox_Click"
            Content="Show similar text matches" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Counts other text that matches the same character-class pattern as the selection. Scroll the mouse wheel over the button to adjust match precision." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Calculator" />

        <CheckBox
            x:Name="CalcShowPaneCheckBox"
            Margin="0,4,0,0"
            Click="CalcShowPaneCheckBox_Click"
            Content="Show calculator pane" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Show a right-side panel that evaluates math expressions as you type them in the editor." />

        <CheckBox
            x:Name="CalcShowErrorsCheckBox"
            Margin="0,4,0,0"
            Click="CalcShowErrorsCheckBox_Click"
            Content="Show calculator errors" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Display expression evaluation errors inline in the calculator pane." />

    </StackPanel>
    </ScrollViewer>
</Page>
