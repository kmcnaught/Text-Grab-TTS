<Page
    x:Class="Text_Grab.Pages.FullscreenGrabSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="FullscreenGrabSettings"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Visible">
    <StackPanel Margin="20,12,40,40" Orientation="Vertical">
        <TextBlock Style="{StaticResource TextHeader}" Text="Fullscreen Grab Settings" />

        <TextBlock
            Margin="0,12,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Defaults" />

        <StackPanel Margin="0,4,0,8">
            <TextBlock Style="{StaticResource TextBodyNormal}" Text="Start mode:" />
            <StackPanel Margin="12,6,0,0">
                <RadioButton
                    x:Name="DefaultModeRadio"
                    Click="DefaultModeRadio_Click"
                    GroupName="FsgStartMode">
                    Default (Standard)
                </RadioButton>
                <RadioButton
                    x:Name="SingleLineModeRadio"
                    Click="SingleLineModeRadio_Click"
                    GroupName="FsgStartMode">
                    Single Line (S)
                </RadioButton>
                <RadioButton
                    x:Name="TableModeRadio"
                    Click="TableModeRadio_Click"
                    GroupName="FsgStartMode">
                    Table (T)
                </RadioButton>
            </StackPanel>
        </StackPanel>

        <StackPanel Margin="0,4,0,8">
            <TextBlock Style="{StaticResource TextBodyNormal}" Text="Selection style:" />
            <StackPanel Margin="12,6,0,0">
                <RadioButton
                    x:Name="RegionSelectionStyleRadio"
                    Click="RegionSelectionStyleRadio_Click"
                    GroupName="FsgSelectionStyle">
                    <StackPanel Orientation="Horizontal">
                        <wpfui:SymbolIcon FontSize="22" Symbol="RectangleLandscape24" />
                        <TextBlock Margin="6,0,0,0">Region select (R)</TextBlock>
                    </StackPanel>
                </RadioButton>
                <RadioButton
                    x:Name="WindowSelectionStyleRadio"
                    Click="WindowSelectionStyleRadio_Click"
                    GroupName="FsgSelectionStyle">
                    <StackPanel Orientation="Horizontal">
                        <wpfui:SymbolIcon FontSize="22" Symbol="WindowMultiple20" />
                        <TextBlock Margin="6,0,0,0">Window select (W)</TextBlock>
                    </StackPanel>
                </RadioButton>
                <RadioButton
                    x:Name="FreeformSelectionStyleRadio"
                    Click="FreeformSelectionStyleRadio_Click"
                    GroupName="FsgSelectionStyle">
                    <StackPanel Orientation="Horizontal">
                        <wpfui:SymbolIcon FontSize="22" Symbol="DrawShape24" />
                        <TextBlock Margin="6,0,0,0">Draw freeform shape (D)</TextBlock>
                    </StackPanel>
                </RadioButton>
                <RadioButton
                    x:Name="AdjustAfterSelectionStyleRadio"
                    Click="AdjustAfterSelectionStyleRadio_Click"
                    GroupName="FsgSelectionStyle">
                    <StackPanel Orientation="Horizontal">
                        <wpfui:SymbolIcon FontSize="22" Symbol="SelectObject24" />
                        <TextBlock Margin="6,0,0,0">Adjust after region selection (A)</TextBlock>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
            <TextBlock
                Margin="24,6,0,0"
                Opacity="0.75"
                Style="{StaticResource TextBodyNormal}"
                Text="Choose how Fullscreen Grab defines the capture area by default. Region select is the standard drag-a-box capture." />
        </StackPanel>

        <CheckBox
            x:Name="SendToEtwCheckBox"
            Margin="0,4,0,0"
            Click="SendToEtwCheckBox_Click"
            Content="Send output to Edit Text Window by default" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Automatically route capture text into the Edit Text Window (same as pressing E)." />

        <!--  Shade overlay option  -->
        <CheckBox
            x:Name="ShadeOverlayCheckBox"
            Margin="0,8,0,0"
            Click="ShadeOverlayCheckBox_Click"
            Content="Dim screen with translucent overlay while selecting" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Controls the transparent overlay shown during Fullscreen Grab selection. Turn off to disable screen dimming." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Post-capture insert" />

        <CheckBox
            x:Name="TryInsertCheckBox"
            Margin="0,4,0,0"
            Click="TryInsertCheckBox_Click"
            Content="Insert captured text into the focused app after closing Fullscreen Grab" />

        <StackPanel
            Margin="24,6,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TextBodyNormal}"
                Text="Insert delay (seconds):" />
            <Slider
                x:Name="InsertDelaySlider"
                Width="200"
                Margin="12,0,0,0"
                IsSnapToTickEnabled="True"
                Maximum="5"
                Minimum="0"
                SmallChange="0.1"
                TickFrequency="0.1"
                ValueChanged="InsertDelaySlider_ValueChanged" />
            <TextBlock
                x:Name="InsertDelayValueText"
                Width="40"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                Style="{StaticResource TextBodyNormal}" />
        </StackPanel>

        <TextBlock
            Margin="24,2,0,0"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="How long to wait before simulating paste (Ctrl+V)." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Post-capture actions" />

        <TextBlock
            Margin="0,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Configure which actions are available for selection to preform after text is captured (Trim lines, Remove duplicates, etc.)." />

        <Button
            x:Name="CustomizeActionsButton"
            Margin="0,0,0,8"
            HorizontalAlignment="Left"
            Click="CustomizeActionsButton_Click"
            Content="Customize Post-Capture Actions..."
            ToolTip="Open editor to add, remove, and reorder post-capture actions" />

        <TextBlock
            x:Name="ActionsCountText"
            Margin="0,0,0,16"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Current actions: Loading..." />

        <TextBlock
            Margin="0,0,0,4"
            Style="{StaticResource TextBodyNormal}"
            Text="Grab Templates" />
        <TextBlock
            Margin="0,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Create reusable templates that OCR specific regions of a captured area and format the result using a template string like &quot;Name: {1}\nEmail: {2}&quot;." />
        <Button
            x:Name="ManageTemplatesButton"
            Margin="0,0,0,16"
            HorizontalAlignment="Left"
            Click="ManageTemplatesButton_Click"
            Content="Manage Grab Templates..."
            ToolTip="Open editor to create, edit, and delete grab templates" />
    </StackPanel>
    </ScrollViewer>
</Page>
