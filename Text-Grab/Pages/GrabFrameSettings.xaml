<Page
    x:Class="Text_Grab.Pages.GrabFrameSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="GrabFrameSettings"
    d:DesignHeight="700"
    d:DesignWidth="800"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Visible">
    <StackPanel Margin="20,12,40,40" Orientation="Vertical">
        <TextBlock Style="{StaticResource TextHeader}" Text="Grab Frame Settings" />

        <TextBlock
            Margin="0,12,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Capture Behavior" />

        <CheckBox
            x:Name="GrabFrameAutoOcrCheckBox"
            Margin="0,4,0,0"
            Click="GrabFrameAutoOcrCheckBox_Click"
            Content="Automatically run OCR on capture" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Freeze and run OCR automatically after dragging the frame. When off, a manual OCR button is shown instead of the Refresh button." />

        <CheckBox
            x:Name="GrabFrameUpdateEtwCheckBox"
            Margin="0,4,0,0"
            Click="GrabFrameUpdateEtwCheckBox_Click"
            Content="Update Edit Text Window on each grab" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="When grabbing, replace the current selection in the Edit Text Window with captured text. When off, text is appended instead." />

        <CheckBox
            x:Name="CloseFrameOnGrabCheckBox"
            Margin="0,4,0,0"
            Click="CloseFrameOnGrabCheckBox_Click"
            Content="Close Grab Frame after grabbing text" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Automatically close the Grab Frame window after a grab or trim executes." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Scroll Wheel Behavior" />

        <StackPanel Margin="12,6,0,0">
            <RadioButton
                x:Name="NoneScrollRadio"
                Click="ScrollBehaviorRadio_Click"
                GroupName="GfScrollBehavior">
                None — scroll wheel does nothing
            </RadioButton>
            <RadioButton
                x:Name="ResizeScrollRadio"
                Click="ScrollBehaviorRadio_Click"
                GroupName="GfScrollBehavior">
                Resize — scroll wheel resizes the frame
            </RadioButton>
            <RadioButton
                x:Name="ZoomScrollRadio"
                Click="ScrollBehaviorRadio_Click"
                GroupName="GfScrollBehavior">
                Zoom — scroll wheel zooms the captured image
            </RadioButton>
            <RadioButton
                x:Name="ZoomWhenFrozenScrollRadio"
                Click="ScrollBehaviorRadio_Click"
                GroupName="GfScrollBehavior">
                Zoom when frozen — zoom only after freezing the frame
            </RadioButton>
        </StackPanel>
        <TextBlock
            Margin="24,6,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Controls what the mouse scroll wheel does while the Grab Frame is active." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Barcodes" />

        <CheckBox
            x:Name="GrabFrameReadBarcodesCheckBox"
            Margin="0,4,0,0"
            Click="GrabFrameReadBarcodesCheckBox_Click"
            Content="Read barcodes in Grab Frame" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Scan for barcodes and QR codes alongside OCR text. Each barcode found appears as its own selectable word border." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Translation" />

        <CheckBox
            x:Name="GrabFrameTranslationCheckBox"
            Margin="0,4,0,0"
            Click="GrabFrameTranslationCheckBox_Click"
            Content="Enable translation overlay (requires Windows AI)" />

        <StackPanel
            Margin="24,6,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TextBodyNormal}"
                Text="Translation language:" />
            <TextBox
                x:Name="GrabFrameTranslationLanguageText"
                Width="180"
                Margin="12,0,0,0"
                LostFocus="GrabFrameTranslationLanguageText_LostFocus" />
        </StackPanel>
        <TextBlock
            Margin="24,2,0,0"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Translates captured text in place using on-device Windows AI — no internet required. Enter the target language name (e.g. English, French, Spanish)." />

    </StackPanel>
    </ScrollViewer>
</Page>
