<Page
    x:Class="Text_Grab.Pages.QuickLookupSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="QuickLookupSettings"
    d:DesignHeight="500"
    d:DesignWidth="800"
    Loaded="Page_Loaded"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Visible">
    <StackPanel Margin="20,12,40,40" Orientation="Vertical">
        <TextBlock Style="{StaticResource TextHeader}" Text="Quick Simple Lookup Settings" />

        <TextBlock
            Margin="0,12,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Lookup File" />

        <TextBlock
            Margin="0,0,0,6"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Path to a CSV file with ShortValue and LongValue columns. Leave empty to use a default cache file stored alongside the app." />

        <StackPanel Orientation="Horizontal">
            <TextBox
                x:Name="LookupFileLocationTextBox"
                Width="340"
                LostFocus="LookupFileLocationTextBox_LostFocus" />
            <Button
                Margin="8,0,0,0"
                Click="BrowseLookupFileButton_Click"
                Content="Browse..." />
        </StackPanel>

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Behavior" />

        <CheckBox
            x:Name="LookupSearchHistoryCheckBox"
            Margin="0,4,0,0"
            Click="LookupSearchHistoryCheckBox_Click"
            Content="Show history in lookup grid" />
        <TextBlock
            Margin="24,0,0,8"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="Append recent Edit Text Window sessions and Grab Frame captures to the bottom of the lookup grid." />

        <TextBlock
            Margin="0,16,0,6"
            FontSize="18"
            FontWeight="Bold"
            Style="{StaticResource TextBodyNormal}"
            Text="Post-selection insert" />

        <CheckBox
            x:Name="TryInsertCheckBox"
            Margin="0,4,0,0"
            Click="TryInsertCheckBox_Click"
            Content="Paste selected value into the previously focused app" />

        <StackPanel
            Margin="24,6,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TextBodyNormal}"
                Text="Insert delay (seconds):" />
            <Slider
                x:Name="InsertDelaySlider"
                Width="200"
                Margin="12,0,0,0"
                IsSnapToTickEnabled="True"
                Maximum="5"
                Minimum="0"
                SmallChange="0.1"
                TickFrequency="0.1"
                ValueChanged="InsertDelaySlider_ValueChanged" />
            <TextBlock
                x:Name="InsertDelayValueText"
                Width="40"
                Margin="12,0,0,0"
                HorizontalAlignment="Left"
                Style="{StaticResource TextBodyNormal}" />
        </StackPanel>
        <TextBlock
            Margin="24,2,0,0"
            Opacity="0.75"
            Style="{StaticResource TextBodyNormal}"
            Text="After pressing Enter to select, Quick Lookup closes and sends Ctrl+V to the previously focused app after this delay — giving you time to switch windows." />

    </StackPanel>
    </ScrollViewer>
</Page>
